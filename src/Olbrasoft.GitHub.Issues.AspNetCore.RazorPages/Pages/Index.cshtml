@page
@model Olbrasoft.GitHub.Issues.AspNetCore.RazorPages.Pages.IndexModel
@{
    ViewData["Title"] = "Hledat GitHub issues";
}

<!-- Database status notification area -->
<div id="dbStatusBanner" class="db-status-banner" style="display: none;">
    <div class="db-status-content">
        <span class="db-status-icon"></span>
        <span class="db-status-message"></span>
        <button id="dbActionBtn" class="db-action-btn" style="display: none;"></button>
        <button id="dbDismissBtn" class="db-dismiss-btn" title="Zavřít">&times;</button>
    </div>
</div>

<div class="search-container">
    <div class="search-header">
        <h1>Hledat GitHub issues</h1>
        <div class="header-actions">
            <!-- Auth controls - shown based on auth status -->
            <div id="authControls" class="auth-controls" style="display: none;">
                <span id="authUser" class="auth-user"></span>
                <a id="logoutLink" href="/logout" class="auth-link">Odhlásit</a>
            </div>
            <a id="loginLink" href="/login" class="auth-link login-link" style="display: none;">
                <span class="github-icon">&#xf09b;</span> Přihlásit přes GitHub
            </a>

            <!-- Sync button - only visible for authenticated owner -->
            <button id="syncBtn" class="sync-btn" title="Synchronizovat data z GitHubu" style="display: none;">
                <span class="sync-icon">&#8635;</span>
                <span class="sync-text">Importovat data</span>
            </button>
            <span id="dbStats" class="db-stats"></span>
        </div>
    </div>

    <form method="get" class="search-form" id="searchForm">
        <div class="search-row">
            <input type="text"
                   name="Query"
                   value="@Model.Query"
                   placeholder="Zadejte hledaný text..."
                   class="search-input" />
            <button type="submit" class="search-button">Hledat</button>
            <button type="button" class="reset-button" onclick="clearSearch()">Vymazat</button>
        </div>

        <div class="repo-filter-row">
            <label>Repozitáře:</label>
            <div class="tag-input-container" id="tagInputContainer">
                <div class="tags" id="selectedTags"></div>
                <input type="text"
                       id="repoSearchInput"
                       placeholder="Zadejte název repozitáře..."
                       autocomplete="off" />
                <div class="autocomplete-dropdown" id="autocompleteDropdown"></div>
            </div>
            <input type="hidden" name="Repos" id="reposHidden" value="@Model.Repos" />
        </div>

        <div class="filter-row">
            <label>Stav:</label>
            <select name="State" class="state-select" onchange="if(document.getElementById('reposHidden').value!==''||document.getElementById('Query').value.trim()!==''){document.getElementById('searchForm').submit();}">
                @if (Model.State == "all") { <option value="all" selected>Vše</option> } else { <option value="all">Vše</option> }
                @if (Model.State == "open") { <option value="open" selected>Otevřený</option> } else { <option value="open">Otevřený</option> }
                @if (Model.State == "closed") { <option value="closed" selected>Zavřený</option> } else { <option value="closed">Zavřený</option> }
            </select>

            <label>Položek na stránku:</label>
            <select name="PageSize" class="page-size-select" onchange="document.getElementById('searchForm').submit();">
                @foreach (var size in Model.PageSizeOptions)
                {
                    if (Model.PageSize == size)
                    {
                        <option value="@size" selected>@size</option>
                    }
                    else
                    {
                        <option value="@size">@size</option>
                    }
                }
            </select>
        </div>
        <!-- Language is now in the site header (_Layout.cshtml) -->
        <input type="hidden" name="Lang" value="@Model.Language" />
        <input type="hidden" name="PageNum" value="1" />
    </form>
</div>

@if (Model.HasSearchCriteria)
{
    var currentUrl = $"/?Query={Uri.EscapeDataString(Model.Query ?? "")}&State={Model.State}&Lang={Model.Language}&PageNum={Model.PageNumber}&PageSize={Model.PageSize}" +
                     (string.IsNullOrEmpty(Model.Repos) ? "" : $"&Repos={Model.Repos}");
    var returnUrlEncoded = Uri.EscapeDataString(currentUrl);

    <div class="results-container">
        <div class="results-header">
            <h2>Výsledky vyhledávání</h2>
            <span class="signalr-status disconnected" title="Připojování..."></span>
            @if (Model.SelectedRepositories.Count() == 1)
            {
                <button id="quickSyncBtn" class="quick-sync-btn" title="Synchronizovat @Model.SelectedRepositories.First().FullName a obnovit">
                    <span class="sync-icon">&#8635;</span> Sync
                </button>
            }
            @if (Model.SearchResult.TotalCount > 0)
            {
                <span class="results-count">
                    Zobrazeno @((Model.PageNumber - 1) * Model.PageSize + 1)-@(Math.Min(Model.PageNumber * Model.PageSize, Model.SearchResult.TotalCount)) z @Model.SearchResult.TotalCount
                </span>
            }
        </div>

        @if (Model.SearchResult.Results.Count == 0)
        {
            <p class="no-results">Žádné výsledky</p>
        }
        else
        {
            // Build lookup: parentId -> list of sub-issues in current results
            var subsByParent = Model.SearchResult.Results
                .Where(r => r.IsSubIssue)
                .GroupBy(r => r.ParentIssueId!.Value)
                .ToDictionary(g => g.Key, g => g.ToList());
            var renderedIds = new HashSet<int>();

            <ul class="results-list">
                @foreach (var result in Model.SearchResult.Results)
                {
                    if (renderedIds.Contains(result.Id)) { continue; }
                    renderedIds.Add(result.Id);

                    // Check if this is a parent issue with sub-issues in current results
                    var hasSubsInResults = subsByParent.ContainsKey(result.Id);
                    var isGroupParent = result.IsParentIssue || hasSubsInResults;

                    if (isGroupParent)
                    {
                        // === PARENT GROUP: parent header + nested sub-issues ===
                        <li class="result-item parent-issue-item" data-issue-id="@result.Id">
                            <div class="result-header">
                                <a href="/Issue/Detail/@result.Id?returnUrl=@returnUrlEncoded" class="result-title">#@result.IssueNumber @result.Title</a>
                                <span class="state-badge @(result.IsOpen ? "state-open" : "state-closed")">
                                    @result.StateCzech
                                </span>
                                @if (result.SubIssueCount > 0)
                                {
                                    var completedCount = result.ClosedSubIssueCount;
                                    var totalSubs = result.SubIssueCount;
                                    var allDone = completedCount == totalSubs;
                                    <span class="sub-issue-progress @(allDone ? "progress-done" : "progress-pending")" title="@completedCount z @totalSubs sub-issues dokončeno">
                                        ◉ @completedCount/@totalSubs
                                    </span>
                                }
                                @foreach (var label in result.Labels)
                                {
                                    <span class="label-badge" style="background-color: #@label.Color; color: @label.TextColor;">@label.Name</span>
                                }
                            </div>
                            <div class="ai-summary-container" data-issue-id="@result.Id">
                                <div class="body-preview">
                                    @if (!string.IsNullOrEmpty(result.BodyPreview)) { @result.BodyPreview }
                                </div>
                                <div class="ai-summary-en" style="display:none;"></div>
                                <div class="ai-summary-cs" style="display:none;"></div>
                            </div>
                            <div class="result-meta">
                                <span class="repository">@result.RepositoryName</span>
                            </div>
                            <div class="result-actions">
                                <a href="/Issue/Detail/@result.Id?returnUrl=@returnUrlEncoded" class="detail-link">Zobrazit detail</a>
                                <a href="@result.Url" target="_blank" class="github-link">GitHub ↗</a>
                                @if (result.IsOpen)
                                {
                                    var hasOpenSubs = result.SubIssueCount > 0 && result.ClosedSubIssueCount < result.SubIssueCount;
                                    var openSubCount = result.SubIssueCount - result.ClosedSubIssueCount;
                                    <button class="issue-state-btn @(hasOpenSubs ? "issue-close-parent-btn" : "issue-close-btn")"
                                            data-issue-id="@result.Id"
                                            data-new-state="closed"
                                            data-open-subs="@(hasOpenSubs ? openSubCount : 0)"
                                            style="display: none;"
                                            title="@(hasOpenSubs ? $"Zavřít s {openSubCount} otevřenými sub-issues" : "Zavřít tento issue")">
                                        <span class="btn-icon">✕</span>
                                        <span class="btn-text">Zavřít</span>
                                    </button>
                                }
                                else
                                {
                                    <button class="issue-state-btn issue-reopen-btn"
                                            data-issue-id="@result.Id"
                                            data-new-state="open"
                                            style="display: none;"
                                            title="Znovu otevřít tento issue">
                                        <span class="btn-icon">↺</span>
                                        <span class="btn-text">Otevřít</span>
                                    </button>
                                }
                            </div>

                            @* Render sub-issues nested inside the parent *@
                            @if (subsByParent.TryGetValue(result.Id, out var subs))
                            {
                                <ul class="sub-issues-inline">
                                    @foreach (var sub in subs)
                                    {
                                        renderedIds.Add(sub.Id);
                                        <li class="result-item sub-issue-item" data-issue-id="@sub.Id">
                                            <div class="result-header">
                                                <span class="sub-issue-indent">↳</span>
                                                <a href="/Issue/Detail/@sub.Id?returnUrl=@returnUrlEncoded" class="result-title">#@sub.IssueNumber @sub.Title</a>
                                                <span class="state-badge @(sub.IsOpen ? "state-open" : "state-closed")">
                                                    @sub.StateCzech
                                                </span>
                                                @if (sub.IsParentIssue)
                                                {
                                                    <span class="sub-issue-progress progress-pending" title="@sub.ClosedSubIssueCount z @sub.SubIssueCount sub-issues dokončeno">
                                                        ◉ @sub.ClosedSubIssueCount/@sub.SubIssueCount
                                                    </span>
                                                }
                                                @foreach (var label in sub.Labels)
                                                {
                                                    <span class="label-badge" style="background-color: #@label.Color; color: @label.TextColor;">@label.Name</span>
                                                }
                                            </div>
                                            <div class="ai-summary-container" data-issue-id="@sub.Id">
                                                <div class="body-preview">
                                                    @if (!string.IsNullOrEmpty(sub.BodyPreview)) { @sub.BodyPreview }
                                                </div>
                                                <div class="ai-summary-en" style="display:none;"></div>
                                                <div class="ai-summary-cs" style="display:none;"></div>
                                            </div>
                                            <div class="result-actions">
                                                <a href="/Issue/Detail/@sub.Id?returnUrl=@returnUrlEncoded" class="detail-link">Detail</a>
                                                <a href="@sub.Url" target="_blank" class="github-link">GitHub ↗</a>
                                                @if (sub.IsOpen)
                                                {
                                                    <button class="issue-state-btn issue-close-btn"
                                                            data-issue-id="@sub.Id"
                                                            data-new-state="closed"
                                                            style="display: none;"
                                                            title="Zavřít tento issue">
                                                        <span class="btn-icon">✕</span>
                                                        <span class="btn-text">Zavřít</span>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="issue-state-btn issue-reopen-btn"
                                                            data-issue-id="@sub.Id"
                                                            data-new-state="open"
                                                            style="display: none;"
                                                            title="Znovu otevřít tento issue">
                                                        <span class="btn-icon">↺</span>
                                                        <span class="btn-text">Otevřít</span>
                                                    </button>
                                                }
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                        </li>
                    }
                    else if (result.IsSubIssue)
                    {
                        // === ORPHAN SUB-ISSUE: parent not in current results ===
                        <li class="result-item sub-issue-orphan" data-issue-id="@result.Id">
                            <div class="result-header">
                                <span class="sub-issue-indent" title="Sub-issue of #@result.ParentIssueNumber">↳ #@result.ParentIssueNumber</span>
                                <a href="/Issue/Detail/@result.Id?returnUrl=@returnUrlEncoded" class="result-title">#@result.IssueNumber @result.Title</a>
                                <span class="state-badge @(result.IsOpen ? "state-open" : "state-closed")">
                                    @result.StateCzech
                                </span>
                                @foreach (var label in result.Labels)
                                {
                                    <span class="label-badge" style="background-color: #@label.Color; color: @label.TextColor;">@label.Name</span>
                                }
                            </div>
                            <div class="ai-summary-container" data-issue-id="@result.Id">
                                <div class="body-preview">
                                    @if (!string.IsNullOrEmpty(result.BodyPreview)) { @result.BodyPreview }
                                </div>
                                <div class="ai-summary-en" style="display:none;"></div>
                                <div class="ai-summary-cs" style="display:none;"></div>
                            </div>
                            <div class="result-meta">
                                <span class="repository">@result.RepositoryName</span>
                                @if (!string.IsNullOrWhiteSpace(Model.Query) && result.IsExactMatch)
                                {
                                    <span class="exact-match">Přesná shoda (#@result.IssueNumber)</span>
                                }
                                else if (!string.IsNullOrWhiteSpace(Model.Query))
                                {
                                    <span class="similarity">Podobnost: @result.SimilarityPercent</span>
                                }
                            </div>
                            <div class="result-actions">
                                <a href="/Issue/Detail/@result.Id?returnUrl=@returnUrlEncoded" class="detail-link">Zobrazit detail</a>
                                <a href="@result.Url" target="_blank" class="github-link">GitHub ↗</a>
                                @if (result.IsOpen)
                                {
                                    <button class="issue-state-btn issue-close-btn"
                                            data-issue-id="@result.Id"
                                            data-new-state="closed"
                                            style="display: none;"
                                            title="Zavřít tento issue">
                                        <span class="btn-icon">✕</span>
                                        <span class="btn-text">Zavřít</span>
                                    </button>
                                }
                                else
                                {
                                    <button class="issue-state-btn issue-reopen-btn"
                                            data-issue-id="@result.Id"
                                            data-new-state="open"
                                            style="display: none;"
                                            title="Znovu otevřít tento issue">
                                        <span class="btn-icon">↺</span>
                                        <span class="btn-text">Otevřít</span>
                                    </button>
                                }
                            </div>
                        </li>
                    }
                    else
                    {
                        // === STANDALONE ISSUE: no parent, no children ===
                        <li class="result-item" data-issue-id="@result.Id">
                            <div class="result-header">
                                <a href="/Issue/Detail/@result.Id?returnUrl=@returnUrlEncoded" class="result-title">#@result.IssueNumber @result.Title</a>
                                <span class="state-badge @(result.IsOpen ? "state-open" : "state-closed")">
                                    @result.StateCzech
                                </span>
                                @foreach (var label in result.Labels)
                                {
                                    <span class="label-badge" style="background-color: #@label.Color; color: @label.TextColor;">@label.Name</span>
                                }
                            </div>
                            <div class="ai-summary-container" data-issue-id="@result.Id">
                                <div class="body-preview">
                                    @if (!string.IsNullOrEmpty(result.BodyPreview)) { @result.BodyPreview }
                                </div>
                                <div class="ai-summary-en" style="display:none;"></div>
                                <div class="ai-summary-cs" style="display:none;"></div>
                            </div>
                            <div class="result-meta">
                                <span class="repository">@result.RepositoryName</span>
                                @if (!string.IsNullOrWhiteSpace(Model.Query) && result.IsExactMatch)
                                {
                                    <span class="exact-match">Přesná shoda (#@result.IssueNumber)</span>
                                }
                                else if (!string.IsNullOrWhiteSpace(Model.Query))
                                {
                                    <span class="similarity">Podobnost: @result.SimilarityPercent</span>
                                }
                            </div>
                            <div class="result-actions">
                                <a href="/Issue/Detail/@result.Id?returnUrl=@returnUrlEncoded" class="detail-link">Zobrazit detail</a>
                                <a href="@result.Url" target="_blank" class="github-link">GitHub ↗</a>
                                @if (result.IsOpen)
                                {
                                    <button class="issue-state-btn issue-close-btn"
                                            data-issue-id="@result.Id"
                                            data-new-state="closed"
                                            style="display: none;"
                                            title="Zavřít tento issue">
                                        <span class="btn-icon">✕</span>
                                        <span class="btn-text">Zavřít</span>
                                    </button>
                                }
                                else
                                {
                                    <button class="issue-state-btn issue-reopen-btn"
                                            data-issue-id="@result.Id"
                                            data-new-state="open"
                                            style="display: none;"
                                            title="Znovu otevřít tento issue">
                                        <span class="btn-icon">↺</span>
                                        <span class="btn-text">Otevřít</span>
                                    </button>
                                }
                            </div>
                        </li>
                    }
                }
            </ul>

            @if (Model.SearchResult.TotalPages > 1)
            {
                <div class="pagination">
                    @if (Model.PageNumber > 1)
                    {
                        <a href="?Query=@Uri.EscapeDataString(Model.Query ?? "")&State=@Model.State&Lang=@Model.Language&PageNum=@(Model.PageNumber - 1)&PageSize=@Model.PageSize@(string.IsNullOrEmpty(Model.Repos) ? "" : $"&Repos={Model.Repos}")" class="page-link">« Předchozí</a>
                    }

                    <span class="page-info">Stránka @Model.PageNumber z @Model.SearchResult.TotalPages</span>

                    @if (Model.PageNumber < Model.SearchResult.TotalPages)
                    {
                        <a href="?Query=@Uri.EscapeDataString(Model.Query ?? "")&State=@Model.State&Lang=@Model.Language&PageNum=@(Model.PageNumber + 1)&PageSize=@Model.PageSize@(string.IsNullOrEmpty(Model.Repos) ? "" : $"&Repos={Model.Repos}")" class="page-link">Další »</a>
                    }
                </div>
            }
        }
    </div>
}

<!-- Sync Modal Dialog -->
<div id="syncModal" class="modal-overlay" style="display: none;">
    <div class="modal-dialog">
        <div class="modal-header">
            <h2>Synchronizace dat</h2>
            <button id="modalCloseBtn" class="modal-close-btn" title="Zavřít">&times;</button>
        </div>
        <div class="modal-body">
            <div class="modal-field">
                <label>Repozitáře:</label>
                <div class="tag-input-container" id="syncTagInputContainer">
                    <div class="tags" id="syncSelectedTags"></div>
                    <input type="text"
                           id="syncRepoSearchInput"
                           placeholder="Zadejte název repozitáře... (prázdné = všechny)"
                           autocomplete="off" />
                    <div class="autocomplete-dropdown" id="syncAutocompleteDropdown"></div>
                </div>
                <small class="field-hint">Prázdné pole = synchronizace všech repozitářů</small>
            </div>
            <div class="modal-field">
                <label class="checkbox-label">
                    <input type="checkbox" id="modalFullRefreshCheckbox" />
                    Plný refresh (stáhnout vše znovu, ignorovat timestamp)
                </label>
            </div>
        </div>
        <div class="modal-footer">
            <button id="modalCancelBtn" class="btn-secondary">Zrušit</button>
            <button id="modalSyncBtn" class="btn-primary">Synchronizovat</button>
        </div>
    </div>
</div>

<!-- Sync Confirmation Modal (Analysis Results) -->
<div id="syncConfirmModal" class="modal-overlay" style="display: none;">
    <div class="modal-dialog">
        <div class="modal-header">
            <h2>Potvrzení synchronizace</h2>
            <button id="confirmCloseBtn" class="modal-close-btn" title="Zavřít">&times;</button>
        </div>
        <div class="modal-body">
            <div id="syncAnalysisContent"></div>
            <div class="modal-field" style="margin-top: 20px;">
                <label class="checkbox-label">
                    <input type="checkbox" id="confirmGenerateEmbeddings" checked />
                    Generovat embeddingy (vyžaduje Cohere API)
                </label>
                <small class="field-hint">Bez embeddingů nebudou issues dostupné v sémantickém vyhledávání</small>
            </div>
        </div>
        <div class="modal-footer">
            <button id="confirmCancelBtn" class="btn-secondary">Zrušit</button>
            <button id="confirmSyncBtn" class="btn-primary">Synchronizovat</button>
        </div>
    </div>
</div>

<!-- Sync Result Modal -->
<div id="syncResultModal" class="modal-overlay" style="display: none;">
    <div class="modal-dialog">
        <div class="modal-header">
            <h2 id="syncResultTitle">Synchronizace dokončena</h2>
            <button id="resultCloseBtn" class="modal-close-btn" title="Zavřít">&times;</button>
        </div>
        <div class="modal-body">
            <div id="syncResultContent"></div>
        </div>
        <div class="modal-footer">
            <button id="resultOkBtn" class="btn-primary">Zavřít</button>
        </div>
    </div>
</div>

<!-- Hidden form for clearing search session -->
<form id="clearSearchForm" method="post" asp-page-handler="ClearSearch" style="display: none;"></form>

@section Scripts {
    <script>
        // Initialize selected repositories from server
        window.initialSelectedRepos = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.SelectedRepositories.Select(r => new { id = r.Id, fullName = r.FullName })));

        // Initialize language setting for SignalR client (use header language or server-side value)
        window.selectedLanguage = window.siteLanguage || '@Model.Language';

        // Clear search function - clears session and reloads page
        function clearSearch() {
            document.getElementById('clearSearchForm').submit();
        }

        // Quick sync for single selected repository
        (function() {
            const btn = document.getElementById('quickSyncBtn');
            if (!btn || !window.initialSelectedRepos || window.initialSelectedRepos.length !== 1) return;

            const repoName = window.initialSelectedRepos[0].fullName;

            btn.addEventListener('click', async function() {
                btn.disabled = true;
                btn.innerHTML = '<span class="sync-icon spinning">&#8635;</span> Synchronizuji...';

                try {
                    const response = await fetch('/api/data/sync', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            repositoryFullNames: [repoName],
                            fullRefresh: false,
                            generateEmbeddings: true
                        })
                    });
                    const result = await response.json();

                    if (result.success) {
                        btn.innerHTML = '<span class="sync-icon">✓</span> Hotovo, obnovuji...';
                        setTimeout(() => location.reload(), 500);
                    } else {
                        btn.innerHTML = '<span class="sync-icon">&#8635;</span> Sync';
                        btn.disabled = false;
                        alert('Chyba synchronizace: ' + result.message);
                    }
                } catch (error) {
                    btn.innerHTML = '<span class="sync-icon">&#8635;</span> Sync';
                    btn.disabled = false;
                    alert('Chyba: ' + error.message);
                }
            });
        })();
    </script>
    <script src="~/js/repo-filter.js" asp-append-version="true"></script>
    <script src="~/js/db-status.js" asp-append-version="true"></script>
    <script src="~/js/issue-updates.js" asp-append-version="true"></script>
}
