@page "{id:int}"
@using Markdig
@model Olbrasoft.GitHub.Issues.AspNetCore.RazorPages.Pages.Issue.DetailModel
@{
    ViewData["Title"] = Model.Issue?.Title ?? "Detail issue";
}

<div class="detail-container" data-issue-id="@Model.Issue?.Id" data-issue-is-open="@Model.Issue?.IsOpen.ToString().ToLower()">
    <div class="nav-buttons nav-buttons-top">
        <a href="@Model.SafeReturnUrl" class="back-link">← Zpět na výsledky</a>
        @if (Model.Issue != null)
        {
            <div class="nav-buttons-right">
                @if (Model.Issue.IsOpen)
                {
                    <button id="closeIssueBtn" class="issue-state-btn issue-close-btn" style="display: none;" title="Zavřít tento issue">
                        <span class="btn-icon">✕</span>
                        <span class="btn-text">Zavřít</span>
                    </button>
                }
                else
                {
                    <button id="reopenIssueBtn" class="issue-state-btn issue-reopen-btn" style="display: none;" title="Znovu otevřít tento issue">
                        <span class="btn-icon">↺</span>
                        <span class="btn-text">Otevřít</span>
                    </button>
                }
                <a href="@Model.Issue.Url" target="_blank" class="github-button">Otevřít na GitHubu ↗</a>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="error-message">
            @Model.ErrorMessage
        </div>
    }
    else if (Model.Issue != null)
    {
        <div class="issue-detail">
            <div class="issue-header">
                <h1>@Model.Issue.Title</h1>
                <span class="state-badge @(Model.Issue.IsOpen ? "state-open" : "state-closed")">
                    @Model.Issue.StateCzech
                </span>
            </div>

            <div class="issue-meta">
                <span class="repository">Repository: <strong>@Model.Issue.RepositoryName</strong></span>
                <span class="issue-number">Issue #@Model.Issue.IssueNumber</span>
                @if (Model.Issue.IsSubIssue)
                {
                    <a href="/Issue/Detail/@Model.Issue.ParentIssueId?returnUrl=@Uri.EscapeDataString(Model.SafeReturnUrl)" class="parent-issue-link">
                        ↳ Parent: #@Model.Issue.ParentIssueNumber @Model.Issue.ParentIssueTitle
                    </a>
                }
            </div>

            @if (Model.Issue.Labels.Count > 0)
            {
                <div class="labels-container">
                    @foreach (var label in Model.Issue.Labels)
                    {
                        <span class="label-badge" style="background-color: #@label.Color; color: @label.TextColor;">@label.Name</span>
                    }
                </div>
            }

            @if (Model.Issue.HasSubIssues)
            {
                var closedCount = Model.Issue.SubIssueClosed;
                var totalCount = Model.Issue.SubIssueTotal;
                var progressPercent = totalCount > 0 ? (int)Math.Round((double)closedCount / totalCount * 100) : 0;
                <div class="sub-issues-section">
                    <div class="sub-issues-header">
                        <h3>Sub-issues</h3>
                        <span class="sub-issues-count">@closedCount / @totalCount dokončeno</span>
                    </div>
                    <div class="sub-issues-progress-bar">
                        <div class="sub-issues-progress-fill" style="width: @(progressPercent)%;"></div>
                    </div>
                    <ul class="sub-issues-list">
                        @foreach (var sub in Model.Issue.SubIssues!)
                        {
                            <li class="sub-issue-entry @(sub.IsOpen ? "" : "sub-issue-closed")">
                                <span class="sub-issue-state-dot @(sub.IsOpen ? "dot-open" : "dot-closed")" title="@(sub.IsOpen ? "Otevřený" : "Zavřený")"></span>
                                <a href="/Issue/Detail/@sub.Id?returnUrl=@Uri.EscapeDataString(Model.SafeReturnUrl)" class="sub-issue-link">
                                    #@sub.IssueNumber @sub.Title
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            }

            <div id="ai-summary-container" data-issue-id="@Model.Issue.Id" data-summary-pending="@Model.SummaryPending.ToString().ToLower()" data-summary-language="@Model.Language" data-selected-language="@Model.Language">
                @if (!string.IsNullOrEmpty(Model.Summary))
                {
                    <div class="ai-summary">
                        <div class="ai-summary-header">
                            <span class="ai-icon">🤖</span>
                            <span class="ai-label">AI Shrnutí</span>
                            @if (!string.IsNullOrEmpty(Model.SummaryProvider))
                            {
                                <span class="ai-provider">@Model.SummaryProvider</span>
                            }
                        </div>
                        <p class="ai-summary-text">@Model.Summary</p>
                    </div>
                }
                else if (!string.IsNullOrEmpty(Model.SummaryError))
                {
                    <div class="ai-summary ai-summary-error">
                        <div class="ai-summary-header">
                            <span class="ai-icon">⚠️</span>
                            <span class="ai-label">AI Shrnutí nedostupné</span>
                        </div>
                        <p class="ai-summary-text">@Model.SummaryError</p>
                    </div>
                }
                else if (Model.SummaryPending)
                {
                    <div class="ai-summary ai-summary-loading">
                        <div class="ai-summary-header">
                            <span class="ai-icon ai-icon-spin">⏳</span>
                            <span class="ai-label">Generuji AI shrnutí...</span>
                        </div>
                        <p class="ai-summary-text">Shrnutí bude za chvíli k dispozici.</p>
                    </div>
                }
            </div>

            <hr />

            <div class="issue-body">
                @if (!string.IsNullOrEmpty(Model.Issue.Body))
                {
                    @Html.Raw(Markdown.ToHtml(Model.Issue.Body, new MarkdownPipelineBuilder()
                        .UseAdvancedExtensions()
                        .Build()))
                }
                else
                {
                    <p class="no-body">Toto issue nemá textový obsah.</p>
                }
            </div>

            <hr />

            <div class="nav-buttons nav-buttons-bottom">
                <a href="@Model.SafeReturnUrl" class="back-link">← Zpět na výsledky</a>
                <div class="nav-buttons-right">
                    @if (Model.Issue.IsOpen)
                    {
                        <button id="closeIssueBtnBottom" class="issue-state-btn issue-close-btn" style="display: none;" title="Zavřít tento issue">
                            <span class="btn-icon">✕</span>
                            <span class="btn-text">Zavřít</span>
                        </button>
                    }
                    else
                    {
                        <button id="reopenIssueBtnBottom" class="issue-state-btn issue-reopen-btn" style="display: none;" title="Znovu otevřít tento issue">
                            <span class="btn-icon">↺</span>
                            <span class="btn-text">Otevřít</span>
                        </button>
                    }
                    <a href="@Model.Issue.Url" target="_blank" class="github-button">Otevřít na GitHubu ↗</a>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .detail-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 20px;
    }

    .nav-buttons {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
    }

    .nav-buttons-top {
        margin-bottom: 20px;
    }

    .nav-buttons-bottom {
        margin-top: 24px;
    }

    .back-link {
        display: inline-block;
        color: #0969da;
        text-decoration: none;
    }

    .back-link:hover {
        text-decoration: underline;
    }

    .error-message {
        background-color: #ffebe9;
        border: 1px solid #ff818266;
        border-radius: 6px;
        padding: 16px;
        color: #cf222e;
    }

    .issue-detail {
        background: white;
        border: 1px solid #d0d7de;
        border-radius: 6px;
        padding: 24px;
    }

    .issue-header {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 16px;
    }

    .issue-header h1 {
        margin: 0;
        font-size: 1.5rem;
        flex: 1;
    }

    .state-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 500;
        white-space: nowrap;
    }

    .state-open {
        background-color: #dafbe1;
        color: #1a7f37;
    }

    .state-closed {
        background-color: #8250df1a;
        color: #8250df;
    }

    .issue-meta {
        display: flex;
        gap: 20px;
        color: #656d76;
        font-size: 0.9rem;
        margin-bottom: 16px;
    }

    .issue-body {
        line-height: 1.6;
    }

    .issue-body h1, .issue-body h2, .issue-body h3, .issue-body h4 {
        margin-top: 24px;
        margin-bottom: 16px;
    }

    .issue-body pre {
        background-color: #f6f8fa;
        border-radius: 6px;
        padding: 16px;
        overflow-x: auto;
    }

    .issue-body code {
        background-color: #f6f8fa;
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.9em;
    }

    .issue-body pre code {
        background: none;
        padding: 0;
    }

    .issue-body ul, .issue-body ol {
        padding-left: 24px;
    }

    .issue-body table {
        border-collapse: collapse;
        width: 100%;
        margin: 16px 0;
    }

    .issue-body th, .issue-body td {
        border: 1px solid #d0d7de;
        padding: 8px 12px;
        text-align: left;
    }

    .issue-body th {
        background-color: #f6f8fa;
    }

    .issue-body blockquote {
        border-left: 4px solid #d0d7de;
        padding-left: 16px;
        margin-left: 0;
        color: #656d76;
    }

    .no-body {
        color: #656d76;
        font-style: italic;
    }

    .github-button {
        display: inline-block;
        background-color: #24292f;
        color: white;
        padding: 10px 20px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 500;
    }

    .github-button:hover {
        background-color: #32383f;
    }

    hr {
        border: none;
        border-top: 1px solid #d0d7de;
        margin: 24px 0;
    }

    /* AI Summary */
    .ai-summary {
        background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
        border: 1px solid #0ea5e9;
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 16px;
    }

    .ai-summary-error {
        background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
        border-color: #f59e0b;
    }

    .ai-summary-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px;
    }

    .ai-icon {
        font-size: 1.2em;
    }

    .ai-label {
        font-weight: 600;
        color: #0369a1;
    }

    .ai-summary-error .ai-label {
        color: #b45309;
    }

    .ai-provider {
        font-size: 0.75em;
        color: #64748b;
        background-color: rgba(255, 255, 255, 0.5);
        padding: 2px 8px;
        border-radius: 12px;
    }

    .cache-indicator, .fresh-indicator {
        font-size: 1em;
        margin-left: 4px;
        cursor: help;
    }

    .cache-indicator {
        color: #059669;
    }

    .fresh-indicator {
        color: #7c3aed;
    }

    .ai-summary-text {
        margin: 0;
        color: #1e3a5f;
        line-height: 1.6;
    }

    .ai-summary-error .ai-summary-text {
        color: #78350f;
    }

    /* AI Summary loading state */
    .ai-summary-loading {
        background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
        border-color: #9ca3af;
    }

    .ai-summary-loading .ai-label {
        color: #6b7280;
    }

    .ai-summary-loading .ai-summary-text {
        color: #6b7280;
    }

    .ai-icon-spin {
        animation: spin 1.5s linear infinite;
    }

    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    /* AI Summary received animation */
    .ai-summary-received {
        animation: summaryReceived 0.5s ease-out;
    }

    @@keyframes summaryReceived {
        0% {
            background-color: #d1fae5;
            transform: scale(1.02);
        }
        100% {
            background-color: transparent;
            transform: scale(1);
        }
    }

    /* Parent issue link */
    .parent-issue-link {
        color: #0969da;
        text-decoration: none;
        font-size: 0.9rem;
    }

    .parent-issue-link:hover {
        text-decoration: underline;
    }

    /* Sub-issues section */
    .sub-issues-section {
        background: #f6f8fa;
        border: 1px solid #d0d7de;
        border-radius: 6px;
        padding: 16px;
        margin-bottom: 16px;
    }

    .sub-issues-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 10px;
    }

    .sub-issues-header h3 {
        margin: 0;
        font-size: 1rem;
        color: #24292f;
    }

    .sub-issues-count {
        font-size: 0.85rem;
        color: #656d76;
        font-weight: 500;
    }

    .sub-issues-progress-bar {
        height: 8px;
        background-color: #e1e4e8;
        border-radius: 4px;
        overflow: hidden;
        margin-bottom: 12px;
    }

    .sub-issues-progress-fill {
        height: 100%;
        background-color: #1a7f37;
        border-radius: 4px;
        transition: width 0.3s ease;
    }

    .sub-issues-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .sub-issue-entry {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 0;
        border-bottom: 1px solid #e1e4e8;
    }

    .sub-issue-entry:last-child {
        border-bottom: none;
    }

    .sub-issue-state-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .dot-open {
        background-color: #1a7f37;
    }

    .dot-closed {
        background-color: #8250df;
    }

    .sub-issue-link {
        color: #24292f;
        text-decoration: none;
        font-size: 0.9rem;
    }

    .sub-issue-link:hover {
        color: #0969da;
        text-decoration: underline;
    }

    .sub-issue-closed .sub-issue-link {
        color: #656d76;
        text-decoration: line-through;
    }

    /* Issue labels */
    .labels-container {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 16px;
    }

    .label-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 16px;
        font-size: 12px;
        font-weight: 500;
        white-space: nowrap;
    }

    /* Title translation styles */
    .title-translating {
        opacity: 0.7;
        position: relative;
    }

    .title-translating::after {
        content: "...";
        animation: ellipsis 1.5s infinite;
    }

    @@keyframes ellipsis {
        0% { content: "."; }
        33% { content: ".."; }
        66% { content: "..."; }
    }

    .title-translated {
        animation: titleHighlight 2s ease-out;
    }

    @@keyframes titleHighlight {
        0% {
            background-color: #d1fae5;
            padding: 4px 8px;
            margin: -4px -8px;
            border-radius: 4px;
        }
        100% {
            background-color: transparent;
            padding: 0;
            margin: 0;
        }
    }

    /* Navigation buttons right group */
    .nav-buttons-right {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    /* Issue state buttons (Close/Reopen) */
    .issue-state-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 10px 16px;
        border: none;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .issue-state-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .issue-close-btn {
        background-color: #cf222e;
        color: white;
    }

    .issue-close-btn:hover:not(:disabled) {
        background-color: #a40e26;
    }

    .issue-reopen-btn {
        background-color: #1a7f37;
        color: white;
    }

    .issue-reopen-btn:hover:not(:disabled) {
        background-color: #116329;
    }

    .issue-state-btn .btn-icon {
        font-size: 14px;
    }

    /* Loading state */
    .issue-state-btn.loading .btn-text {
        opacity: 0.7;
    }

    .issue-state-btn.loading .btn-icon {
        animation: spin 1s linear infinite;
    }
</style>

@section Scripts {
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
    <script src="~/js/detail-updates.js"></script>
}
